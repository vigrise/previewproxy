# ============================================================
# App / Server
# ============================================================

# Runtime environment. Options: development, production
# APP_ENV=development

# HTTP port the server listens on
# PORT=8080

# Max in-flight requests before returning 503
# MAX_CONCURRENT_REQUESTS=256

# Log level filter (see https://docs.rs/tracing-subscriber)
# RUST_LOG=previewproxy=info,tower_http=info

# ============================================================
# Security
# ============================================================

# Secret key used to sign/verify request URLs. Leave empty to disable signing.
# HMAC_KEY=

# Comma-separated list of upstream hostnames allowed as image sources. Leave empty to allow all.
# ALLOWED_HOSTS=

# Value for the Access-Control-Allow-Origin header. Use * to allow all.
# CORS_ALLOW_ORIGIN=*

# How long (seconds) the browser may cache CORS preflight responses.
# CORS_MAX_AGE_SECS=600

# ============================================================
# Upstream Fetching
# ============================================================

# Max seconds to wait for an upstream HTTP response before aborting.
# FETCH_TIMEOUT_SECS=10

# Max size (bytes) of a source file accepted for processing. Default: 20 MB.
# MAX_SOURCE_BYTES=20971520

# ============================================================
# Cache
# ============================================================

# Max size (MB) of the in-memory (L1) cache.
# CACHE_MEMORY_MAX_MB=256

# Time-to-live (seconds) for entries in the in-memory cache.
# CACHE_MEMORY_TTL_SECS=3600

# Directory used for the disk (L2) cache.
# CACHE_DIR=/tmp/previewproxy

# Time-to-live (seconds) for entries on disk.
# CACHE_DISK_TTL_SECS=86400

# Max total size (MB) of the disk cache. Leave empty for unlimited.
# CACHE_DISK_MAX_MB=

# How often (seconds) the background cleanup task runs.
# CACHE_CLEANUP_INTERVAL_SECS=600

# ============================================================
# Sources - S3-compatible (AWS, Cloudflare R2, etc.)
# ============================================================

# Set to true to enable S3 as an image source.
# S3_ENABLED=false

# Name of the S3 bucket to read from.
# S3_BUCKET=

# AWS region (or equivalent) of the bucket.
# S3_REGION=us-east-1

# Credentials for S3 authentication.
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# Custom endpoint URL for S3-compatible services (e.g. Backblaze B2, Cloudflare R2,...).
# Leave empty for AWS.
# S3_ENDPOINT=

# ============================================================
# Sources - Local Filesystem
# ============================================================

# Set to true to enable serving images from the local filesystem.
# LOCAL_ENABLED=false

# Absolute path to the root directory for local image files.
# LOCAL_BASE_DIR=

# ============================================================
# Sources - URL Aliases
# ============================================================

# Comma-separated alias=hostname mappings to rewrite short aliases in request URLs.
# Example: "cdn=cdn.example.com,assets=assets.example.com"
# URL_ALIASES=

# ============================================================
# Disallow Lists
# ============================================================

# Blocks matching input source URLs (comma-separated regex patterns).
# INPUT_DISALLOW_LIST=

# Blocks matching transform operation names (comma-separated regex patterns).
# TRANSFORM_DISALLOW_LIST=

# Blocks matching output format names (comma-separated regex patterns).
# OUTPUT_DISALLOW_LIST=
